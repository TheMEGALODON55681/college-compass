# sqlite (default) or postgresql://user:pass@host:5432/dbname - see README's
# "Postgres migration" section before pointing this at Postgres.
DATABASE_URL=sqlite:///./college_compass.db

# Grounded counsellor chat (/chat). Any OpenAI-compatible endpoint works -
# Ollama, LM Studio, vLLM, or a hosted provider. Defaults to a local
# Ollama-style endpoint if unset. LLM_API_KEY is only needed for providers
# that require one; local servers usually ignore it.
LLM_ENDPOINT=http://localhost:11434/v1
LLM_MODEL=
LLM_API_KEY=
